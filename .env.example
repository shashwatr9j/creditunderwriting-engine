# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values. The .env file is optional —
# without it, the engine runs in deterministic local-heuristic mode.
# ─────────────────────────────────────────────────────────────────────────────

# Enables LLM-powered agents. Leave unset to run in heuristic mode.
ANTHROPIC_API_KEY=

# Optional: model identifier for LLM mode.
UNDERWRITING_MODEL=claude-sonnet-4-6

# Optional: annual base interest rate (%) applied before the tier spread.
BASE_INTEREST_RATE=10.5
